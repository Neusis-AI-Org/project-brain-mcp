#!/bin/bash
#
# List required OAuth scopes for enabled tools.
#
# Usage:
#   script/list-scopes [--toolsets=...] [--output=text|json|summary]
#
# Examples:
#   script/list-scopes
#   script/list-scopes --toolsets=all --output=json
#   script/list-scopes --toolsets=repos,issues --output=summary
#

set -e

cd "$(dirname "$0")/.."

# Build the server if it doesn't exist or is outdated
if [ ! -f mcp-project-brain ] || [ cmd/mcp-project-brain/list_scopes.go -nt mcp-project-brain ]; then
    echo "Building mcp-project-brain..." >&2
    go build -o mcp-project-brain ./cmd/mcp-project-brain
fi

exec ./mcp-project-brain list-scopes "$@"
